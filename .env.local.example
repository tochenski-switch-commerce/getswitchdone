# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend (email sending)
RESEND_API_KEY=re_xxxxx

# Email forwarding
INBOUND_EMAIL_SECRET=your-webhook-secret
NEXT_PUBLIC_INBOUND_EMAIL=gsd@mail.yourdomain.com

# APNs Push Notifications
APNS_KEY_ID=your-10-char-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_PRIVATE_KEY=base64-encoded-p8-file-contents
APNS_BUNDLE_ID=com.getswitchdone.boards
APNS_ENVIRONMENT=development
PUSH_WEBHOOK_SECRET=your-webhook-secret

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
